# ============ Deep-SemP .gitignore ============

# Local path config (copy of paths.example.sh)
configs/paths.sh

# Large data, models, and all pipeline outputs
results/
data/
*.npy
*.pt
*.ckpt
*.csv

# Sequence data & references
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fa
*.fa.gz
*.fasta
*.fasta.gz
*.faa
*.gtf
*.gff
*.gff3

# BLAST databases
*.nhr
*.nin
*.nsq
*.ndb
*.not
*.ntf
*.nto
*.njs

# BUSCO lineage databases
busco_downloads/
*.hmm
*.prfl

# Alignment / index binaries
*.bam
*.sam
*.bai
*.jf

# Figures & tables regenerated by analysis scripts
*.png
*.pdf
*.tsv
*.svg

# Logs
*.log
nohup.out
*.out

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
